{
 "root": true,
 "env": {
  "browser": true,
  "es2021": true,
  "node": true
 },
 "extends": [
  "eslint:recommended",
  "@typescript-eslint/recommended",
  "plugin:react/recommended",
  "plugin:react-hooks/recommended"
 ],
 "parser": "@typescript-eslint/parser",
 "parserOptions": {
  "ecmaFeatures": {
    "jsx": true
  },
  "sourceType": "module",
  "ecmaVersion": "latest"
 },
 "plugins": [
  "react",
  "react-hooks",
  "@typescript-eslint"
 ],
 "rules": {
  "no-console": "warn",
  "no-debugger": "error",
  "prefer-const": "error",
  "no-var": "error",
  "react/react-in-jsx-scope": "off",
  "@typescript-eslint/no-unused-vars": "error",
  "@typescript-eslint/explicit-function-return-type": "warn",
  "@typescript-eslint/no-explicit-any": "warn"
 },
 "settings": {
  "react": {
    "version": "detect"
  }
 }
}