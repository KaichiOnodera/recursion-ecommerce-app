{
  "compilerOptions": {
    /* Language and Environment */
    "target": "es2016",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    /* Output Settings */
    "outDir": "./dist", // ここにビルド後のJSを出力
    "baseUrl": "./",
    "paths": {
      "@shared/*": [
        "../shared/*"
      ]
    },
  },
  "include": [
    "src/**/*",
    "../shared/**/*"
  ]
}