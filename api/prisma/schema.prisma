generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Items {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  type        Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ItemImages ItemImages[]
}

model ItemImages {
  id        Int      @id @default(autoincrement())
  itemId    Int
  src       String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  item Items @relation(fields: [itemId], references: [id])

  @@index([itemId])
}

model Users {
  id         Int      @id @default(autoincrement())
  lastName   String
  firstName  String
  email      String   @unique
  password   String
  isResigned Boolean  @default(false)
  role       UserRole @default(USER)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum UserRole {
  USER
  ADMIN
}
