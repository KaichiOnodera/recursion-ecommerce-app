generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Cart {
  id        Int      @id @default(autoincrement())
  sessionId String?  @unique @db.VarChar(64)
  userId    Int?     @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      Users?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  cartItems CartItems[]
}

model CartItems {
  id        Int      @id @default(autoincrement())
  cartId    Int
  itemId    Int
  amount    Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart Cart  @relation(fields: [cartId], references: [id], onDelete: Cascade)
  item Items @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([cartId, itemId])
  @@index([cartId])
  @@index([itemId])
}

model Inventory {
  id        Int      @id @default(autoincrement())
  amount    Int      @default(0)
  itemId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  item Items @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
}

model Items {
  id            Int      @id @default(autoincrement())
  name          String
  description   String
  type          Int      @default(1)
  displayStatus String   @default("private")
  price         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  ItemImages ItemImages[]
  Inventory  Inventory[]
  CartItems  CartItems[]
  OrderItems OrderItems[]
}

model ItemImages {
  id        Int      @id @default(autoincrement())
  itemId    Int
  src       String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  item Items @relation(fields: [itemId], references: [id])

  @@index([itemId])
}

model Orders {
  id          Int      @id @default(autoincrement())
  userId      Int?
  cartId      Int?
  lastName    String
  firstName   String
  email       String
  address     String
  totalPrice  Int
  orderStatus String   @default("pending") @db.VarChar(32)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user               Users?                    @relation(fields: [userId], references: [id], onDelete: SetNull)
  cart               Cart?                     @relation(fields: [cartId], references: [id], onDelete: SetNull)
  orderItems         OrderItems[]
  paymentExternalIds OrderPaymentExternalIds[]

  @@index([userId])
}

model OrderPaymentExternalIds {
  id               Int      @id @default(autoincrement())
  orderId          Int
  /**
   * STRIPE
   */
  provider         String   @db.VarChar(191)
  paymentSessionId String?  @db.VarChar(255)
  paymentId        String?  @db.VarChar(255)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  order Orders @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([provider, paymentSessionId])
  @@unique([provider, paymentId])
  @@index([orderId])
  @@index([provider])
}

model OrderPaymentExternalIds {
  id               Int      @id @default(autoincrement())
  orderId          Int
  /**
   * STRIPE
   */
  provider         String   @db.VarChar(191)
  paymentSessionId String?  @db.VarChar(255)
  paymentId        String?  @db.VarChar(255)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  order Orders @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([provider, paymentSessionId])
  @@unique([provider, paymentId])
  @@index([orderId])
  @@index([provider])
}

model OrderItems {
  id        Int      @id @default(autoincrement())
  orderId   Int
  itemId    Int?
  itemName  String
  itemPrice Int
  amount    Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order Orders @relation(fields: [orderId], references: [id], onDelete: Cascade)
  item  Items? @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@unique([orderId, itemId])
  @@index([orderId])
}

model Users {
  id         Int      @id @default(autoincrement())
  lastName   String
  firstName  String
  email      String   @unique
  password   String
  isResigned Boolean  @default(false)
  role       UserRole @default(USER)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  cart   Cart?
  orders Orders[]
}

enum UserRole {
  USER
  ADMIN
}
